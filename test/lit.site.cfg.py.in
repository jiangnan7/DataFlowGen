@LIT_SITE_CFG_IN_HEADER@

config.llvm_tools_dir = lit_config.substitute("@LLVM_TOOLS_DIR@")
config.llvm_lib_dir = lit_config.substitute("@LLVM_LIBRARY_DIR@")
config.mlir_tools_dir = lit_config.substitute("@MLIR_TOOLS_DIR@")
config.heteacc_obj_root = "@PROJECT_BINARY_DIR@"
config.heteacc_tools_dir = "@LLVM_RUNTIME_OUTPUT_INTDIR@"
config.heteacc_src_root = "@PROJECT_SOURCE_DIR@"
config.enable_bindings_python = @HETEACC_ENABLE_BINDINGS_PYTHON@

import lit.llvm
lit.llvm.initialize(lit_config, config)

lit_config.load_config(config, "@PROJECT_SOURCE_DIR@/test/lit.cfg.py")
